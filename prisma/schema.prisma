generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Trip {
  id               String   @id @default(cuid())
  originLabel      String
  destinationLabel String
  originLat        Float
  originLon        Float
  destLat          Float
  destLon          Float
  selectedVehicles String[]
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}
